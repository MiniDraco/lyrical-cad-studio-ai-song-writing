{
  "name": "lyrical-cad-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev -H 0.0.0.0 -p 4000",
    "dev:local": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev -p 4000",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "cross-env NEXT_TELEMETRY_DISABLED=1 next start -H 0.0.0.0 -p 4000",
    "start:local": "cross-env NEXT_TELEMETRY_DISABLED=1 next start -p 4000",
    "lint": "next lint",
    "dev:plain": "next dev -H 0.0.0.0 -p 4000",
    "lan": "node scripts/lan-info.js",
    "firewall:open": "powershell -ExecutionPolicy Bypass -File scripts/firewall-open.ps1",
    "firewall:close": "powershell -ExecutionPolicy Bypass -File scripts/firewall-close.ps1"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "html2canvas": "^1.4.1",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5"
  }
}
